{
  "info": {
    "name": "Proyecto Bancario - Clientes y Cuentas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Clientes - Crear",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{clientesBaseUrl}}/api/clientes",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Jose Lema\",\n  \"genero\": \"Masculino\",\n  \"edad\": 35,\n  \"identificacion\": \"1234567890\",\n  \"direccion\": \"Otavalo sn y principal\",\n  \"telefono\": \"098254785\",\n  \"contrasena\": \"1234\",\n  \"estado\": true\n}"
        }
      }
    },
    {
      "name": "Clientes - Patch",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{clientesBaseUrl}}/api/clientes/{{clienteId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"direccion\": \"Otavalo sn y principal 100\",\n  \"telefono\": \"0991112233\"\n}"
        }
      }
    },
    {
      "name": "Cuentas - Crear",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{cuentasBaseUrl}}/api/cuentas",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"tipoCuenta\": \"Ahorro\",\n  \"saldoInicial\": 2000,\n  \"estado\": true,\n  \"clienteId\": {{clienteId}}\n}"
        }
      }
    },
    {
      "name": "Movimientos - Crear",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{cuentasBaseUrl}}/api/movimientos",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"numeroCuenta\": \"478758\",\n  \"tipoMovimiento\": \"Retiro\",\n  \"valor\": -575\n}"
        }
      }
    },
    {
      "name": "Reporte por rango",
      "request": {
        "method": "GET",
        "url": "{{cuentasBaseUrl}}/api/reportes?fecha=2022-02-08,2022-02-10&clienteId={{clienteId}}"
      }
    }
  ],
  "variable": [
    {
      "key": "clientesBaseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "cuentasBaseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "clienteId",
      "value": "1"
    }
  ]
}

